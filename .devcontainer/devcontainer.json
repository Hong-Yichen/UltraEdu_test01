{
  "name": "UltraEdu",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && ([ -f .env ] || cp .env.example .env)",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "UltraEdu",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
