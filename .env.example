FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# DATABASE_URL and UPLOAD_FOLDER are intentionally left unset — app/config.py
# already computes safe absolute paths (<repo>/instance/app.db and
# <repo>/instance/uploads) that work regardless of your current working
# directory. Only set these if you need to point elsewhere (e.g. Postgres in
# production, or a separate uploads volume), and always use absolute paths —
# a relative UPLOAD_FOLDER can resolve differently between `flask seed` and
# `flask run` if they're ever invoked from different working directories,
# which makes previously-seeded files silently "disappear" (404).
MAX_CONTENT_LENGTH_MB=50

# Optional: only needed once the AI hint stub is swapped for a real call
ANTHROPIC_API_KEY=
