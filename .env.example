FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# DATABASE_URL is intentionally left unset — app/config.py already computes a safe
# absolute path (<repo>/instance/app.db) that works regardless of your current
# working directory. Only set this if you need to point at a different database
# (e.g. Postgres in production), and use an absolute path if it's still SQLite.
UPLOAD_FOLDER=instance/uploads
MAX_CONTENT_LENGTH_MB=50

# Optional: only needed once the AI hint stub is swapped for a real call
ANTHROPIC_API_KEY=
